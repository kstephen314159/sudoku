    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^24.1.0",
    "eslint": "^10.0.3",
    "tsx": "^4.21.0",
    "vite": "^7.3.1",
    "vitest": "^3.0.0"
  }
}
